# Anhloom — environment variables
# Copy to .env.local for local development

# Sanity CMS (see sanity/SETUP.md)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Backend API (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_KEY=dev-internal-api-key

# Site URL for SEO canonical, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://anhloom.com

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# reCAPTCHA (contact and careers forms)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Vercel deployment (CI only — set as GitHub secrets)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
